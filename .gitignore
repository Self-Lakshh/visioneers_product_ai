# --- Secrets (NEVER commit) ---
.env
.env.local
.env.*.local
**/.env

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
*.log

# --- Node ---
node_modules/
frontend/dist/
frontend/.vite/
*.local

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Docker ---
*.override.yml

# --- Misc ---
*.bak
*.tmp
