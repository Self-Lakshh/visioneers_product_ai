# =============================================================================
# VISIONEERS PRODUCT AI — Central Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_ENV=development                    # development | staging | production
APP_VERSION=0.1.0

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true                    # Set to false in production
SECRET_KEY=change-me-to-a-random-256-bit-hex-string
ALLOWED_ORIGINS=http://localhost:5173  # Comma-separated list for production

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/visioneers_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=visioneers_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=                        # Leave empty for dev; set in production

# --- Frontend (Vite) ---
# All frontend env vars MUST be prefixed with VITE_ to be exposed to the client
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=Visioneers Product AI
VITE_APP_ENV=development

# --- AI / ML ---
OPENAI_API_KEY=sk-...                  # Your OpenAI key (backend only)
ANTHROPIC_API_KEY=                     # Leave empty if unused

# --- Auth ---
JWT_SECRET=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
